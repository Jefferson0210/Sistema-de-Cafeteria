# Copia a .env (o exporta estas variables en tu entorno/IDE). NO comitees valores reales.

# --- Base de datos ---
DB_USER=root
DB_PASSWORD=

# --- JWT (clave >= 256 bits; genera una NUEVA, la anterior se filtró en git) ---
# openssl rand -base64 32
JWT_SECRET=reemplaza-por-clave-aleatoria-larga

# --- Google OAuth ---
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com

# --- Correo / SMTP ---
MAIL_USER=tu-correo@gmail.com
MAIL_PASSWORD=tu-app-password-de-gmail

# --- CORS (orígenes permitidos, separados por coma) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
